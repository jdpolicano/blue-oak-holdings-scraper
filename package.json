{
  "name": "scrapy-brokers-poc",
  "version": "1.0.0",
  "description": "A top secret project for BOH.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "export DRY_RUN=true && npm run build && npm run start | npx pino-pretty && unset DRY_RUN",
    "debug": "export LOG_LEVEL=debug && npm run dev && unset LOG_LEVEL",
    "scrape:site": "sh -c 'if [ -z \"$1\" ]; then echo \"Usage: npm run scrape:site -- <site>\" >&2; exit 1; fi; DRY_RUN=true CONFIG_PATH=./config/local.config.json LOG_LEVEL=${LOG_LEVEL:-info} SCRAPER_SITES=\"$1\" node dist/index.js' --",
    "scrape:site:debug": "LOG_LEVEL=debug npm run scrape:site --",
    "docker-dev-local": "docker build -t scrapy-brokers-poc . && docker run -m 4g --cpus=2 -e DRY_RUN=true -e CONFIG_PATH=./config/local.config.json scrapy-brokers-poc",
    "docker-dev": "docker build -t scrapy-brokers-poc . && docker run -m 4g --cpus=2 -e DRY_RUN=true scrapy-brokers-poc",
    "docker-debug": "docker build -t scrapy-brokers-poc . && docker run -m 4g --cpus=2 -e DRY_RUN=true -e LOG_LEVEL=debug scrapy-brokers-poc",
    "install-browser": "playwright install --with-deps chromium",
    "prepare": "husky",
    "cfn-lint": "cfn-lint ./infra/**/*.yaml",
    "aws:ops": "tsx scripts/aws-ops.ts",
    "aws:image:build-push": "tsx scripts/aws-ops.ts image build-push",
    "aws:image:cleanup-untagged": "tsx scripts/aws-ops.ts image cleanup-untagged",
    "aws:image:delete": "tsx scripts/aws-ops.ts image delete",
    "aws:deploy:scheduled": "tsx scripts/aws-ops.ts deploy scheduled",
    "aws:task:logs": "tsx scripts/aws-ops.ts task logs",
    "aws:task:run-dry-run": "tsx scripts/aws-ops.ts task run-dry-run",
    "aws:run-dry-run": "tsx scripts/run-aws-dry-run.ts",
    "aws:logs:tail": "aws logs tail /ecs/blue-oak-holdings-scraper --region us-east-1 --follow"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdpolicano/scrapy-brokers-poc.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jdpolicano/scrapy-brokers-poc/issues"
  },
  "homepage": "https://github.com/jdpolicano/scrapy-brokers-poc#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.913.0",
    "@aws-sdk/client-ses": "^3.913.0",
    "@aws-sdk/lib-storage": "^3.913.0",
    "@aws-sdk/s3-request-presigner": "^3.916.0",
    "cheerio": "^1.2.0",
    "csv": "^6.4.1",
    "env-schema": "^6.1.0",
    "graffle": "^8.0.0-next.187",
    "graphql": "^16.11.0",
    "handlebars": "^4.7.8",
    "is-docker": "^4.0.0",
    "p-retry": "^7.1.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.1",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.916.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1072.0",
    "@aws-sdk/client-ecr": "^3.1072.0",
    "@aws-sdk/client-ecs": "^3.916.0",
    "@aws-sdk/client-eventbridge": "^3.916.0",
    "@aws-sdk/client-sts": "^3.1072.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.6.2",
    "@types/pino": "^7.0.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
